  "systemd": {
    "units": [
      {
        "contents": "[Service]\nType=oneshot\nExecStart=/usr/sbin/semodule -i /etc/ioflair/support/iscsiadm-fix.cil\nRemainAfterExit=yes\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "iscsiadm-fix-selinux-policy.service"
      },
      {
        "contents": "[Unit]\nDescription=Set iSCSI replacement timeout for faster Longhorn failover\nConditionPathExists=/etc/iscsi/iscsid.conf\n[Service]\nType=oneshot\nExecStart=/bin/sed -i 's/node.session.timeo.replacement_timeout = .*/node.session.timeo.replacement_timeout = 30/' /etc/iscsi/iscsid.conf\nRemainAfterExit=yes\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "iscsi-timeout-fix.service"
      },
      {
        "contents": "[Unit]\nDescription=Finalize staged OS update and signal Kured to reboot\n[Service]\nType=oneshot\nExecStart=/usr/local/bin/ostree-finalize-bridge.sh\n",
        "name": "zincati-kured-bridge.service"
      },
      {
        "contents": "[Unit]\nDescription=Periodically check for staged OS updates\n[Timer]\nOnBootSec=5min\nOnUnitActiveSec=15min\n[Install]\nWantedBy=timers.target\n",
        "enabled": true,
        "name": "zincati-kured-bridge.timer"
      },
      {
        "mask": true,
        "name": "fstrim.timer"
      }
    ]
  }
}
